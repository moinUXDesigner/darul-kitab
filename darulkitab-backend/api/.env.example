# Copy this file to darulkitab-backend/api/.env on the server
# and fill in your live credentials.

APP_NAME=Quran Fahmi
APP_BASE_URL=https://quranfahmi.in
MAIL_FROM_ADDRESS=moinshaik@quranfahmi.in
MAIL_FROM_NAME=Quran Fahmi
